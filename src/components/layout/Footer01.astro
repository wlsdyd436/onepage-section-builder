---
// [Footer01] 사이트 마지막 마감 영역이다. ContactCTA01이 "전환"을 담당한다면, Footer01은
// 전환 이후 사용자가 다시 훑어볼 수 있는 업체 정보/하단 내비게이션/연락 링크/저작권을
// 안정적으로 정리해 "완성된 사이트"처럼 보이게 하는 역할이다. ContactCTA01을 대체하지 않는다.
//
// Header01과 마찬가지로 페이지 전역 레이아웃 성격이라 index.astro에서 <main> 바깥,
// StickyMobileCTA01 앞에 형제 요소로 배치한다(아래 index.astro 참고). 다만 Header01/
// StickyMobileCTA01과 달리 fixed 요소가 아니므로 showroom에서 그대로 preview 가능하다.
//
// StickyMobileCTA01은 fixed로 화면 하단에 고정되는 별도 컴포넌트라 이 컴포넌트를 수정하지
// 않는다. 대신 모바일에서 Footer01 마지막 내용이 그 바에 가려지지 않도록 Footer01 자체에
// 넉넉한 하단 padding(pb-28, lg 이상에서는 pb-16)을 둔다.
export interface FooterNavItem {
  label: string;
  target: string;
}

interface Props {
  id?: string;
  businessName?: string;
  description?: string;
  navItems?: FooterNavItem[];
  phone?: string;
  kakaoUrl?: string;
  address?: string;
  businessHours?: string;
  businessInfoNote?: string;
  copyright?: string;
}

const {
  id = 'footer',
  businessName,
  description,
  navItems = [],
  phone,
  kakaoUrl,
  address,
  businessHours,
  businessInfoNote,
  copyright,
} = Astro.props;
---

<footer
  id={id}
  class="w-full border-t border-neutral-800 bg-neutral-950 px-5 pb-28 pt-16 text-white md:px-6 lg:px-8 lg:pb-16"
>
  <div class="mx-auto grid max-w-6xl grid-cols-1 gap-10 md:grid-cols-3">
    <!-- 브랜드/업체명 + 짧은 설명 -->
    <div class="flex min-w-0 flex-col gap-3">
      {businessName && (
        <p class="break-keep break-words text-lg font-bold text-white">{businessName}</p>
      )}
      {description && (
        <p class="break-keep break-words text-sm leading-relaxed text-neutral-400">
          {description}
        </p>
      )}
    </div>

    <!-- 하단 내비게이션: 다른 섹션의 id로 이동하는 앵커 링크 모음. flex-wrap으로 좁은 화면에서 -->
    <!-- 자연스럽게 줄바꿈된다. -->
    <div class="flex min-w-0 flex-col gap-3">
      <p class="text-xs font-semibold tracking-widest text-neutral-500">바로가기</p>
      <nav class="flex flex-wrap gap-x-4 gap-y-2">
        {navItems.map((item) => (
          <a
            href={`#${item.target}`}
            class="min-w-0 break-keep break-words text-sm text-neutral-300 hover:text-white"
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>

    <!-- 연락 링크 + 기본 업체 정보 -->
    <div class="flex min-w-0 flex-col gap-3">
      <p class="text-xs font-semibold tracking-widest text-neutral-500">연락처</p>
      <div class="flex flex-col gap-2 text-sm">
        {phone && (
          <a
            href={`tel:${phone}`}
            aria-label={`전화 걸기: ${phone}`}
            class="min-w-0 break-keep break-words text-neutral-300 hover:text-white"
          >
            전화 {phone}
          </a>
        )}
        {kakaoUrl && (
          <a
            href={kakaoUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="카카오 상담 채널 열기"
            class="min-w-0 break-keep break-words text-neutral-300 hover:text-white"
          >
            카카오 상담
          </a>
        )}
        {address && (
          <p class="min-w-0 break-keep break-words text-neutral-400">{address}</p>
        )}
        {businessHours && (
          <p class="min-w-0 break-keep break-words text-neutral-400">{businessHours}</p>
        )}
      </div>
    </div>
  </div>

  <!-- 사업자 정보 placeholder + 저작권: 실제 사업자번호는 넣지 않고, 필요 시 안전한 안내 문구만 표시한다. -->
  <div class="mx-auto mt-12 max-w-6xl border-t border-neutral-800 pt-6">
    {businessInfoNote && (
      <p class="break-keep break-words text-xs text-neutral-500">{businessInfoNote}</p>
    )}
    {copyright && (
      <p class="mt-2 break-keep break-words text-xs text-neutral-600">{copyright}</p>
    )}
  </div>
</footer>
