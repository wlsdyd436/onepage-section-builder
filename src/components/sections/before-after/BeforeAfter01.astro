---
import MediaImage from '../../media/MediaImage.astro';
import type { MediaItemInput } from '../../../types/media';

// [BeforeAfter01] 시공 전/후 사진을 나란히 비교해 보여주는 신뢰 섹션이다.
// PortfolioGrid01(시공 사례) 다음, ContactCTA01(상담 문의) 이전에 배치되어
// "사례를 봤으니 실제로 얼마나 달라지는지" 확신을 준 뒤 상담으로 이어지는 흐름을 만든다.
//
// 이번 MVP는 안정적인 카드형 비교 UI까지만 다룬다. 드래그 가능한 전후 비교 슬라이더는
// 모바일/접근성/브라우저 호환성 리스크가 있어 이번 단계에서는 만들지 않는다.
//
// 이미지는 항상 공통 MediaImage.astro로 렌더링한다. PortfolioGrid01과 동일하게
// mediaResolver/mediaDisplay 규칙(확장자 탐색, fit/position/aspectRatio, fallback 배경)을
// 그대로 물려받는다.
export interface BeforeAfterItem {
  title: string;
  location?: string;
  size?: string;
  scope?: string;
  description?: string;
  beforeImage?: MediaItemInput;
  afterImage?: MediaItemInput;
}

interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  description?: string;
  items?: BeforeAfterItem[];
}

const {
  id = 'before-after',
  eyebrow = 'BEFORE & AFTER',
  title = '공간은 이렇게 달라집니다',
  description = '시공 전후의 변화를 한눈에 확인해보세요.',
  items = [],
} = Astro.props;
---

<section id={id} class="w-full bg-neutral-900 px-5 py-20 text-white md:px-6 lg:px-8">
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-sm font-semibold tracking-[0.2em] text-amber-300">{eyebrow}</p>
    <h2 class="mt-4 break-keep text-3xl font-bold sm:text-4xl">{title}</h2>
    <p class="mt-4 break-keep text-neutral-300">{description}</p>
  </div>

  <!-- 카드 목록: 모바일/태블릿/PC 모두 세로로 쌓는다(카드 자체 배치는 단순 리스트). -->
  <!-- 각 카드 내부의 before/after 이미지 2장만 sm 이상에서 2열로 나뉜다. -->
  <div class="mx-auto mt-12 flex max-w-5xl flex-col gap-10">
    {items.map((item) => (
      <article class="overflow-hidden rounded-xl border border-neutral-700 bg-neutral-800">
        <div class="grid grid-cols-1 sm:grid-cols-2">
          <div class="relative">
            {item.beforeImage ? (
              <MediaImage
                media={item.beforeImage}
                defaultAspectRatio="video"
                alt={`${item.title} 시공 전`}
              />
            ) : (
              <div class="aspect-video w-full bg-neutral-800" />
            )}
            <span class="absolute left-3 top-3 rounded-full bg-neutral-950/80 px-3 py-1 text-xs font-semibold text-white">
              BEFORE
            </span>
          </div>

          <div class="relative">
            {item.afterImage ? (
              <MediaImage
                media={item.afterImage}
                defaultAspectRatio="video"
                alt={`${item.title} 시공 후`}
              />
            ) : (
              <div class="aspect-video w-full bg-neutral-800" />
            )}
            <span class="absolute left-3 top-3 rounded-full bg-amber-400/90 px-3 py-1 text-xs font-semibold text-neutral-950">
              AFTER
            </span>
          </div>
        </div>

        <div class="flex flex-col gap-2 p-5">
          <h3 class="break-keep text-lg font-bold">{item.title}</h3>

          <p class="text-sm text-neutral-400">
            {[item.location, item.size, item.scope].filter(Boolean).join(' · ')}
          </p>

          {item.description && (
            <p class="break-keep text-sm text-neutral-400">{item.description}</p>
          )}
        </div>
      </article>
    ))}
  </div>
</section>
