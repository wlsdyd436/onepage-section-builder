---
// [ServiceCards01] 이 업체가 제공하는 인테리어 서비스 범위를 카드 형태로 보여주는
// 설명/전환 보조 섹션이다. FAQ01(자주 묻는 질문) 다음, ContactCTA01(상담 문의) 이전에
// 배치되어 "내가 원하는 시공도 상담 가능한가?"를 문의 직전에 빠르게 판단하게 해준다.
//
// 이번 MVP는 필터/탭/carousel/modal 없이 안정적인 카드 그리드로만 구현한다. 아이콘
// 라이브러리 대신 텍스트 중심으로 구성하고, features/tags는 작은 pill로 표현한다.
//
// FAQ01/ProcessSteps01에서 정리한 것처럼 title/description/feature/note 모두 처음부터
// break-keep + break-words를 적용한다. feature pill은 좁은 모바일에서도 화면 밖으로
// 밀려나지 않도록 flex-wrap + min-w-0을 함께 사용한다.
export interface ServiceItem {
  title: string;
  description?: string;
  features?: string[];
  note?: string;
}

interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  description?: string;
  items?: ServiceItem[];
}

const {
  id = 'services',
  eyebrow = '시공 서비스',
  title = '공간에 맞는 서비스를 제안합니다',
  description = '주거 공간부터 상업 공간까지 목적과 예산에 맞춰 상담해드립니다.',
  items = [],
} = Astro.props;
---

<section id={id} class="w-full bg-neutral-900 px-5 py-20 text-white md:px-6 lg:px-8">
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-sm font-semibold tracking-[0.2em] text-amber-300">{eyebrow}</p>
    <h2 class="mt-4 break-keep break-words text-3xl font-bold sm:text-4xl">{title}</h2>
    <p class="mt-4 break-keep break-words text-neutral-300">{description}</p>
  </div>

  <!-- 반응형 열 수: 모바일 1열, md(768px, 태블릿) 2열, lg(1024px, PC) 3열. -->
  <!-- min-w-0으로 grid 트랙 안에서 카드가 내용 때문에 트랙보다 넓어지지 않게 막는다. -->
  <div class="mx-auto mt-12 grid max-w-6xl grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
    {items.map((item) => (
      <article class="flex min-w-0 flex-col gap-3 rounded-xl border border-neutral-700 bg-neutral-800 p-6">
        <h3 class="break-keep break-words text-lg font-bold">{item.title}</h3>

        {item.description && (
          <p class="break-keep break-words text-sm leading-relaxed text-neutral-300">
            {item.description}
          </p>
        )}

        <!-- feature/tag pill: flex-wrap으로 줄바꿈을 허용하고, 각 pill에도 min-w-0 + -->
        <!-- break-words를 둬서 태그 하나가 공백 없이 길더라도 카드/화면 밖으로 밀려나지 않게 한다. -->
        {item.features && item.features.length > 0 && (
          <div class="mt-1 flex flex-wrap gap-2">
            {item.features.map((feature) => (
              <span class="min-w-0 break-keep break-words rounded-full bg-neutral-700 px-3 py-1 text-xs text-neutral-200">
                {feature}
              </span>
            ))}
          </div>
        )}

        {item.note && (
          <p class="mt-auto break-keep break-words text-xs text-neutral-500">{item.note}</p>
        )}
      </article>
    ))}
  </div>
</section>
