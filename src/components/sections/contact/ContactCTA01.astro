---
// [ContactCTA01] Header CTA / Hero 버튼 / StickyMobileCTA01의 #contact 링크가 실제로
// 이동하는 목적지 섹션이다. id가 "contact"인 이 <section>이 없으면 그 링크들은 아무 데도
// 이동하지 못한다.
//
// 초기 MVP에서는 이름/전화번호/문의내용을 입력받는 자체 문의폼(form/input/textarea)을 만들지
// 않는다. 사전조사 결과에 따라 개인정보를 직접 수집하지 않고, 전화(tel:)와 카카오 상담 외부
// 링크만으로 상담을 연결하는 것이 초기 단계에서 더 안전하다고 판단했기 때문이다.
// 나중에 실제 문의폼을 추가하려면 개인정보 수집 동의와 개인정보처리방침 페이지가 먼저
// 준비되어야 한다 — 그 전까지는 이 방식을 유지한다.
interface Props {
  id?: string;
  title?: string;
  description?: string;
  phone?: string;
  kakaoUrl?: string;
  address?: string;
  businessName?: string;
}

const {
  id = 'contact',
  title = '무료 상담 문의',
  description = '공간에 맞는 인테리어 상담을 도와드립니다.',
  phone,
  kakaoUrl,
  address,
  businessName,
} = Astro.props;
---

<section id={id} class="w-full bg-neutral-950 px-5 py-20 text-white md:px-6 lg:px-8">
  <div class="mx-auto max-w-3xl text-center">
    <h2 class="text-3xl font-bold sm:text-4xl">{title}</h2>
    <p class="mt-4 break-keep text-neutral-300">{description}</p>

    <!-- CTA 버튼 영역: 모바일은 세로로 쌓이고(flex-col), sm 이상에서 가로로 배치된다. -->
    <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
      <!-- 전화 상담 버튼: phone 값이 있을 때만 tel: 링크로 렌더링한다. 탭하면 바로 전화 앱이 열린다. -->
      {phone && (
        <a
          href={`tel:${phone}`}
          aria-label={`전화 상담: ${phone}`}
          class="flex h-12 items-center justify-center rounded-lg bg-amber-400 px-6 text-sm font-semibold text-neutral-950 transition hover:bg-amber-300 sm:flex-1"
        >
          전화 상담 {phone}
        </a>
      )}

      <!-- 카카오 상담 버튼: kakaoUrl이 있을 때만 렌더링한다. 사이트를 벗어나는 외부 링크라 -->
      <!-- target="_blank"로 새 탭에서 열고, rel="noopener noreferrer"로 보안/성능 이슈를 막는다. -->
      {kakaoUrl && (
        <a
          href={kakaoUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="카카오 상담 채널 열기"
          class="flex h-12 items-center justify-center rounded-lg border border-neutral-500 px-6 text-sm font-semibold text-neutral-100 transition hover:bg-white/10 sm:flex-1"
        >
          카카오 상담
        </a>
      )}
    </div>

    <!-- 업체 정보 카드: businessName/address가 있을 때만 표시한다. -->
    {(businessName || address) && (
      <div class="mt-10 rounded-xl border border-neutral-700 bg-neutral-800 p-6 text-center">
        {businessName && <p class="font-semibold text-white">{businessName}</p>}
        {address && <p class="mt-1 text-sm text-neutral-400">{address}</p>}
      </div>
    )}
  </div>
</section>
