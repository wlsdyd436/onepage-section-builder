---
import BaseLayout from '../layouts/BaseLayout.astro';
import { sectionRegistry } from '../lib/sectionRegistry';

// showroom은 개발자/고객이 등록된 모든 섹션을 실제 화면으로 바로 확인할 수 있는 전시장 페이지다.
// sectionRegistry에 새 섹션을 등록하기만 하면 이 페이지에서 자동으로 목록/미리보기가 늘어난다.
// 이번 MVP는 "섹션을 눈으로 확인한다"까지만 다룬다 — 고객이 섹션을 선택해서 저장하는 기능,
// 선택 결과로 preset을 자동 생성하는 기능, CMS/admin 화면은 이번 단계에 포함하지 않는다.
// 실제 고객용 index.astro는 이 registry를 아직 사용하지 않는다 — index.astro는 지금처럼
// 컴포넌트를 직접 import해서 쓰는 인테리어 데모 페이지 역할을 그대로 유지하고,
// registry 기반 동적 렌더링으로 바꾸는 것은 client config에 sections 구성이 실제로
// 필요해지는 다음 단계 이후의 일이다.
const previewEntries = sectionRegistry.filter((entry) => entry.showInShowroom);
const hiddenEntries = sectionRegistry.filter((entry) => !entry.showInShowroom);

// 카테고리별로 묶어서 보여주기 위해 등장 순서를 유지하며 카테고리 목록을 뽑는다.
const categories = [...new Set(previewEntries.map((entry) => entry.category))];
---

<BaseLayout title="Section Showroom" description="등록된 섹션을 한눈에 확인하는 전시장 페이지">
  <!-- Header01/StickyMobileCTA01은 페이지 전역 레이아웃/고정 UI라 여기서는 import하지 않는다. -->
  <!-- (StickyMobileCTA01은 fixed로 화면 하단에 고정되므로, 그대로 쓰면 아래로 쌓이는 여러 섹션 -->
  <!-- 미리보기들을 계속 가리게 되어 전시장 페이지에는 적합하지 않다.) -->
  <main class="w-full bg-neutral-950 px-5 py-16 text-white md:px-6 lg:px-8">
    <header class="mx-auto max-w-4xl text-center">
      <p class="text-sm font-semibold tracking-[0.3em] text-amber-300">SECTION SHOWROOM</p>
      <h1 class="mt-4 text-3xl font-bold sm:text-4xl">등록된 섹션 전시장</h1>
      <p class="mt-4 break-keep text-neutral-300">
        섹션을 새로 만들 때마다 sectionRegistry에 등록하고, 이 페이지에서 실제 화면으로 바로 확인합니다.
      </p>
      <p class="mt-6 text-sm text-neutral-400">
        전체 {sectionRegistry.length}개 등록 / 미리보기 {previewEntries.length}개 표시
      </p>
    </header>

    {categories.map((category) => (
      <section class="mx-auto mt-16 max-w-6xl">
        <h2 class="text-xl font-bold text-amber-300">{category}</h2>

        <div class="mt-6 flex flex-col gap-10">
          {previewEntries
            .filter((entry) => entry.category === category)
            .map((entry) => {
              // Astro에서 배열마다 다른 컴포넌트를 렌더링하려면, 컴포넌트 팩토리를
              // 대문자로 시작하는 지역 변수에 담아 <Component /> 형태로 써야 한다.
              const Component = entry.component;
              return (
                <div class="overflow-hidden rounded-xl border border-neutral-700">
                  <div class="border-b border-neutral-700 bg-neutral-900 p-5">
                    <div class="flex flex-wrap items-center gap-3">
                      <h3 class="text-lg font-bold">{entry.name}</h3>
                      <span class="rounded-full bg-neutral-700 px-3 py-1 text-xs text-neutral-200">
                        {entry.status}
                      </span>
                    </div>
                    <p class="mt-2 break-keep text-sm text-neutral-400">{entry.description}</p>
                  </div>

                  <div class="bg-neutral-950">
                    <Component {...entry.previewProps} />
                  </div>
                </div>
              );
            })}
        </div>
      </section>
    ))}

    {hiddenEntries.length > 0 && (
      <section class="mx-auto mt-16 max-w-6xl border-t border-neutral-800 pt-10">
        <h2 class="text-xl font-bold text-neutral-400">미리보기 제외 (layout / fixed)</h2>
        <ul class="mt-4 flex flex-col gap-3">
          {hiddenEntries.map((entry) => (
            <li class="rounded-lg border border-neutral-800 bg-neutral-900 p-4">
              <p class="font-semibold text-neutral-200">{entry.name}</p>
              <p class="mt-1 break-keep text-sm text-neutral-500">{entry.notes}</p>
            </li>
          ))}
        </ul>
      </section>
    )}
  </main>
</BaseLayout>
