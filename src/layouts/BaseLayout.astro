---
import '../styles/global.css';

const {
  title = '원페이지 홈페이지',
  description = '소상공인 원페이지 홈페이지'
} = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />

    <!-- 모바일 반응형을 위해 필수인 viewport 설정이다. -->
    <!-- viewport-fit=cover가 있어야 iOS Safari에서 env(safe-area-inset-*) 값이 실제로 0이 아닌 -->
    <!-- 값으로 계산된다. 이게 없으면 StickyMobileCTA01의 pb-[env(safe-area-inset-bottom)]가 -->
    <!-- iPhone에서 항상 0으로 취급돼 홈 인디케이터 영역을 피하는 효과가 전혀 없다. -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <!-- 검색 결과나 브라우저 탭에서 사용할 기본 설명이다. -->
    <meta name="description" content={description} />

    <title>{title}</title>
  </head>

  <!-- 실제 페이지는 전부 다크 테마라 body 기본 배경도 맞춰둔다. -->
  <!-- (흰 배경으로 두면 iOS Safari의 오버스크롤 바운스 때 상/하단 여백에서 흰색이 잠깐 노출된다.) -->
  <body class="bg-neutral-950 text-white">
    <!-- 각 페이지의 실제 내용이 이 slot 안에 들어온다. -->
    <slot />
  </body>
</html>